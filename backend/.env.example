# ── LLM Provider ─────────────────────────────────────
# "groq"   → fast, free tier, good for dev/testing
# "gemini" → more accurate, good for production
LLM_PROVIDER=groq

GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# ── Config A: Fast Mode ───────────────────────────────
VECTOR_DB=faiss
CHUNK_SIZE=300

# ── Config B: Accurate Mode ───────────────────────────
# VECTOR_DB=chroma
# CHUNK_SIZE=700
